# Java backend (set true when Spring Boot is running on port 8080)
# Start API: cd backend && mvn spring-boot:run
VITE_USE_JAVA_API=false

# API base URL when Java is enabled
# Dev with Vite proxy: /api
# Direct: http://localhost:8080/api
# Production (socialthngs.com): point at your deployed API
# VITE_API_BASE_URL=https://api.socialthngs.com/api
VITE_API_BASE_URL=/api

# --- Spring Boot (backend/.env or host env) ---
# JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# CHECKOUT_MOCK_ENABLED=true
# SPRING_PROFILES_ACTIVE=prod
# DATABASE_URL=jdbc:postgresql://...
# DATABASE_USERNAME=
# DATABASE_PASSWORD=

# Bottom-right locale display (defaults: Minneapolis, Minnesota, America/Chicago)
# VITE_SITE_CITY=Minneapolis
# VITE_SITE_COUNTRY=Minnesota
# VITE_SITE_TIMEZONE=America/Chicago
